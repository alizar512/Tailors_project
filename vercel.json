{
  "functions": {
    "api/**/*.php": { "runtime": "vercel-php@0.7.0" },
    "admin/**/*.php": { "runtime": "vercel-php@0.7.0" },
    "tailor/**/*.php": { "runtime": "vercel-php@0.7.0" },
    "includes/**/*.php": { "runtime": "vercel-php@0.7.0" },
    "*.php": { "runtime": "vercel-php@0.7.0" }
  },
  "routes": [
    { "src": "/css/(.*)", "dest": "/css/$1" },
    { "src": "/js/(.*)", "dest": "/js/$1" },
    { "src": "/images/(.*)", "dest": "/images/$1" },
    { "src": "/uploads/(.*)", "dest": "/uploads/$1" },
    { "src": "/(admin|tailor|api|includes)/(.*).php", "dest": "/$1/$2.php" },
    { "src": "/(.*).php", "dest": "/$1.php" },
    { "src": "/", "dest": "/index.php" }
  ]
}